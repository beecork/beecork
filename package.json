{
  "name": "beecork",
  "version": "1.3.2",
  "description": "Claude Code always-on infrastructure — a phone number, a memory, and an alarm clock",
  "type": "module",
  "bin": {
    "beecork": "dist/index.js"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node -e \"require('fs').chmodSync('dist/index.js', 0o755)\"",
    "dev": "tsx src/index.ts",
    "dev:daemon": "tsx src/daemon.ts",
    "test": "vitest",
    "lint": "eslint src/",
    "build:css": "tailwindcss --content src/dashboard/html.ts --minify",
    "prepublishOnly": "npm test && npm run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@whiskeysockets/baileys": "^6.7.0",
    "better-sqlite3": "^12.8.0",
    "commander": "^13.0.0",
    "discord.js": "^14.25.1",
    "node-cron": "^4.0.0",
    "node-telegram-bot-api": "^0.67.0",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.0",
    "@types/node-telegram-bot-api": "^0.64.0",
    "@types/uuid": "^10.0.0",
    "eslint": "^10.1.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.58.0",
    "vitest": "^3.0.0"
  },
  "files": [
    "dist/"
  ],
  "keywords": [
    "claude",
    "claude-code",
    "telegram",
    "whatsapp",
    "discord",
    "mcp",
    "model-context-protocol",
    "ai",
    "ai-agent",
    "automation",
    "cron",
    "cli",
    "chatbot",
    "scheduling"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/beecork/beecork.git"
  },
  "homepage": "https://beecork.com",
  "bugs": {
    "url": "https://github.com/beecork/beecork/issues"
  },
  "author": "Beecork <hello@beecork.com>",
  "license": "MIT"
}
